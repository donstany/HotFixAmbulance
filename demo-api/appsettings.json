{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Elastic": {
    "Uri": "",
    "IndexFormat": "logs-{0:yyyy.MM.dd}"
  },
  "Database": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "DemoDb": "Server=localhost,14333;Database=HotFixDemo;User Id=sa;Password=Your_strong_Password123!;Encrypt=True;TrustServerCertificate=True;"
  },
  "LogFile": {
    "Path": "logs/demo-api-.log"
  }
}
