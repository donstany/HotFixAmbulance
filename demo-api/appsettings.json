{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Elastic": {
    "Uri": "",
    "IndexFormat": "logs-{0:yyyy.MM.dd}"
  },
  "LogFile": {
    "Path": "logs/demo-api-.log"
  }
}
