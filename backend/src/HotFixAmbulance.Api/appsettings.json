{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "ConnectionString": "Data Source=hotfix.db"
  },
  "Apis": {
    "ConfigPath": ""
  },
  "Triage": {
    "DefaultLookbackHours": 24,
    "MaxRangeDays": 30
  },
  "Analysis": {
    "Strategy": "Heuristic"
  },
  "Llm": {
    "Provider": "Qwen",
    "Endpoint": "http://localhost:11434",
    "Model": "qwen2.5:3b",
    "TimeoutSeconds": 30
  },
  "Elastic": {
    "Uri": "http://localhost:9200",
    "IndexPattern": "logs-*",
    "PageSize": 1000,
    "MaxDocuments": 10000,
    "MaxRetries": 3
  },
  "Git": {
    "CacheRoot": ""
  }
}

