{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "ConnectionString": "Data Source=hotfix.db"
  },
  "Apis": {
    "ConfigPath": ""
  },
  "Elastic": {
    "Uri": "http://localhost:9200",
    "IndexPattern": "logs-*",
    "PageSize": 1000,
    "MaxDocuments": 10000,
    "MaxRetries": 3
  },
  "Git": {
    "CacheRoot": ""
  }
}

