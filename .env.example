# Required scopes (do not commit real secrets)
# Copy to `.env` and fill in. The demo runner reads this file.

# --- myPos Elasticsearch ---
HFA_ELASTIC__URI=https://elastic.mypos.example:9200
HFA_ELASTIC__USERNAME=
HFA_ELASTIC__PASSWORD=
HFA_ELASTIC__INDEXPATTERN=logs-*

# --- Git insights ---
# {apiName} is substituted at runtime
HFA_GIT__BASEURLTEMPLATE=https://github.com/myPOStech/{apiName}.git
HFA_GIT__BRANCH=main
HFA_GIT__AUTHTOKEN=

# --- Backend ---
HFA_API__URL=http://localhost:5080

# --- Frontend ---
VITE_HFA_API_URL=http://localhost:5080
